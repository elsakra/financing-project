# Vercel / Railway — optional durable storage (Upstash Redis free tier)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Slack Incoming Webhook URL — alerts on each form submission (do not commit real URL)
SLACK_WEBHOOK_URL=

# Vercel / Railway — protect GET /api/leads export
LEADS_ADMIN_SECRET=

# If set to 1, /api/submit returns 503 when Redis is not configured (no log fallback)
DISABLE_LOG_FALLBACK=

# Build-time (scripts/inject-site-url.js) — override first-party submit URL
# Use full URL when form is on Vercel but API is on Railway, e.g. https://xxx.up.railway.app/api/submit
SUBMIT_ENDPOINT=
